{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/logo.png", "dest": "/logo.png" },
    {
      "src": "/things/(.*)",
      "dest": "https://stranger-quiz.vercel.app/$1"
    },
    {
      "src": "/things",
      "dest": "https://stranger-quiz.vercel.app/"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
